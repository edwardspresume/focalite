{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "focalite",
  "version": "0.3.0",
  "identifier": "com.edlinux.focalite",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Focalite",
        "width": 850,
        "height": 900,
        "minWidth": 640,
        "minHeight": 420,
        "resizable": true,
        "center": true,
        "alwaysOnTop": false,
        "decorations": true,
        "shadow": true,
        "skipTaskbar": false,
        "focus": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
